# backend/.env.example
# ════════════════════════════════════════════════════════════════
# CKYC Platform — Backend Environment Variables
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values for local dev.
# NEVER commit .env — it is in .gitignore.
# On Render: paste each variable into the Environment dashboard.
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (Supabase) ──────────────────────────────────────────
# Found in: Supabase dashboard → Settings → Database → Connection string
# MUST include ?sslmode=require at the end
DATABASE_URL=postgresql://postgres:IKTltPObCNUL7ONM@db.jmimjiqbrueygsooghtm.supabase.co:5432/postgres

# ── Redis (Upstash) ──────────────────────────────────────────────
# Found in: Upstash console → Redis → Details → .env tab
# MUST start with rediss:// (double s = TLS)
REDIS_URL=rediss://default:[token]@[host].upstash.io:[port]

# ── JWT Auth ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 64 characters. Treat like a password — never share.
JWT_SECRET=
JWT_EXPIRY=8h

# ── CRON Webhook Security ────────────────────────────────────────
# Generate same way as JWT_SECRET. Minimum 32 characters.
# This value must also be set in cron-job.org as the x-cron-secret header.
CRON_TRIGGER_SECRET=
CRON_TIMEZONE=Asia/Kolkata
CRON_SCHEDULE=30 4 * * 1-6

# ── Cloudflare R2 ────────────────────────────────────────────────
# Found in: Cloudflare dashboard → R2 → Manage R2 API tokens
# R2_PUBLIC_ENDPOINT format: https://{ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ckyc-mvp-production
R2_PUBLIC_ENDPOINT=

# ── Email (Resend) ───────────────────────────────────────────────
# Found in: resend.com → API Keys
# EMAIL_FROM_ADDRESS must be a verified domain in Resend dashboard
# EMAIL_OPS_RECIPIENT can be comma-separated for multiple recipients
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=alerts@yourdomain.com
EMAIL_OPS_RECIPIENT=ops@yourdomain.com

# ── Gmail (read by Python scripts directly — never by Node.js) ───
# Standard Gmail address used for IMAP access
# App password: Google Account → Security → 2FA → App passwords
# Generate a dedicated app password — do NOT use your main password
GMAIL_ADDRESS=ops-gmail@yourdomain.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Python Scripts ───────────────────────────────────────────────
# On Render: /app/backend/python
# Locally: absolute path to backend/python folder
PYTHON_SCRIPT_PATH=./backend/python
PYTHON_TIMEOUT_MS=30000

# ── CORS ─────────────────────────────────────────────────────────
# Your Cloudflare Pages URL after frontend is deployed
# Locally: http://localhost:5173 (Vite default)
FRONTEND_URL=http://localhost:5173